<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="kh.dajagong.user.mapper.UserMapper">
	<select id="login" resultType="kh.dajagong.user.model.vo.User">
	    SELECT * FROM "USER"
	    WHERE user_id=#{userId} AND pwd=#{pwd} AND status='Y'
	</select>

</mapper>