<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="kh.dajagong.qa.mapper.QaMapper">


	<select id="getListCount" resultType="_int">
		SELECT COUNT(*)
		FROM QUESTION
		WHERE STATUS = 'Y'
	</select>


	<select id="selectQaList" resultType="kh.dajagong.qa.model.vo.Question">
		SELECT *
		FROM QUESTION
		WHERE STATUS = 'Y'
		ORDER BY Q_INDEX DESC
	</select>
	</mapper>